{
  "name": "totem",
  "version": "1.0.2",
  "description": "totem de autoAtendimento",
  "main": "./out/main/index.js",
  "author": "totem.com",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jhoelber/TotemArrecadacao.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview --outDir=dist",
    "dev": "electron-vite dev --outDir=dist",
    "package": "electron-vite build --outDir=dist && electron-forge package",
    "make ": "electron-vite build --outDir=dist && electron-forge make",
    "build": "npm run typecheck && electron-vite build",
    "backend": "json-server --watch db.json --port 5000",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --config",
    "publish:win": "npm run build && electron-builder --win --publish always",
    "release:patch": "npm version patch --no-git-tag-version",
    "release:minor": "npm version minor --no-git-tag-version",
    "release:major": "npm version major --no-git-tag-version",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config"
  },
  "dependencies": {
    "@cloudinary/react": "^1.13.0",
    "@cloudinary/url-gen": "^1.19.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@google-cloud/speech": "^7.2.1",
    "@mui/material": "^5.15.17",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "json-server": "^1.0.0-alpha.23",
    "libreoffice-convert": "^1.6.0",
    "mammoth": "^1.12.0",
    "pdf-to-printer": "^5.6.1",
    "pdfjs-dist": "^4.10.38",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^6.30.3",
    "react-routes": "^0.2.6",
    "scrollreveal": "^4.0.9",
    "simple-keyboard": "^3.8.121"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^2.0.0",
    "@electron-toolkit/eslint-config-ts": "^1.0.1",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^18.19.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "axios": "^1.6.5",
    "chrome": "^0.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "electron-dl": "^3.5.2",
    "electron-is-dev": "^2.0.0",
    "electron-localshortcut": "^3.2.1",
    "electron-modal": "^1.0.0",
    "electron-online": "^1.0.0",
    "electron-pdf-window": "^1.0.12",
    "electron-virtual-keyboard": "^1.0.7",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "is-online": "^4.0.2",
    "open": "^10.0.3",
    "pdf-poppler": "^0.2.1",
    "pdf-to-img": "^2.1.2",
    "pdf2pic": "^3.1.1",
    "postcss": "^8.4.38",
    "prettier": "^3.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "webpack-dev-server": "^5.0.4"
  },
  "build": {
    "appId": "com.autoAtendimento.totem",
    "productName": "Totem",
    "icon": "../totem/build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "./out/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Jhoelber",
        "repo": "TotemArrecadacao",
        "releaseType": "release"
      }
    ]
  },
  "overrides": {
    "@babel/runtime": "7.29.2",
    "@tootallnate/once": "3.0.1",
    "@xmldom/xmldom": "0.8.12",
    "braces": "3.0.3",
    "cross-spawn": "7.0.6",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "jws": "4.0.1",
    "path-to-regexp": "1.9.0",
    "picomatch": "2.3.2",
    "tmp": "0.2.5",
    "underscore": "1.13.8",
    "yaml": "1.10.3"
  }
}
