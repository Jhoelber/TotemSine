{
  "name": "totem",
  "version": "1.0.2",
  "description": "totem de autoAtendimento",
  "main": "./out/main/index.js",
  "author": "totem.com",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jhoelber/TotemArrecadacao.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview --outDir=dist",
    "dev": "electron-vite dev --outDir=dist",
    "package": "electron-vite build --outDir=dist && electron-forge package",
    "make ": "electron-vite build --outDir=dist && electron-forge make",
    "build": "npm run typecheck && electron-vite build",
    "backend": "json-server --watch db.json --port 5000",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win --config",
    "publish:win": "npm run build && electron-builder --win --publish always",
    "release:patch": "npm version patch --no-git-tag-version",
    "release:minor": "npm version minor --no-git-tag-version",
    "release:major": "npm version major --no-git-tag-version",
    "build:mac": "npm run build && electron-builder --mac --config",
    "build:linux": "npm run build && electron-builder --linux --config"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "json-server": "^1.0.0-alpha.23",
    "libreoffice-convert": "^1.8.1",
    "pdf-to-printer": "^5.8.0",
    "pdfjs-dist": "^4.10.38",
    "react-router-dom": "^6.30.4"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^18.19.9",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "electron": "^40.10.6",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.38.0",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.5.16",
    "prettier": "^3.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.3.3",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.autoAtendimento.totem",
    "productName": "Totem",
    "icon": "../totem/build/icon.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "./out/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "Jhoelber",
        "repo": "TotemArrecadacao",
        "releaseType": "release"
      }
    ]
  },
  "overrides": {
    "@babel/runtime": "7.29.2",
    "@tootallnate/once": "3.0.1",
    "@xmldom/xmldom": "0.8.13",
    "braces": "3.0.3",
    "cross-spawn": "7.0.6",
    "glob": "10.5.0",
    "js-yaml": "4.1.1",
    "jws": "4.0.1",
    "path-to-regexp": "1.9.0",
    "picomatch": "2.3.2",
    "tmp": "0.2.7",
    "underscore": "1.13.8",
    "yaml": "1.10.3"
  }
}
